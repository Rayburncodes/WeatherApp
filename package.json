{
  "name": "weather-app",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "dev:server": "npm -w server run dev",
    "build": "npm -w client run build && npm -w server run build",
    "prisma:generate": "npx prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --name init --schema ./prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema ./prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
